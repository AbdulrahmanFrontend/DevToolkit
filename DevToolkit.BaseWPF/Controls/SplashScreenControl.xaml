<UserControl x:Name="SplashScreen" x:Class="DevToolkit.BaseWPF.Controls.SplashScreenControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DevToolkit.BaseWPF.Controls"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">

    <Grid x:Name="SplashGrid">

        <StackPanel x:Name="Container" Margin="0,0,0,0" HorizontalAlignment="Center"
        VerticalAlignment="Center">

            <Image x:Name="SplashLogo" Width="129" Height="121"
               Source="{Binding LogoPath}" Margin="0,0,0,5"/>

            <TextBlock x:Name="SplashTitle" FontSize="28" FontWeight="Bold" 
           Text="{Binding Title}" HorizontalAlignment="Center"/>

            <TextBlock x:Name="SplashSubTitle" FontSize="16" Margin="0,10,0,0" 
           Text="{Binding SubTitle}" HorizontalAlignment="Center"/>

            <TextBlock x:Name="SplashLoading" FontSize="12" Margin="0,10,0,0" 
           Text="{Binding StatusMessage}" HorizontalAlignment="Center"/>

            <ProgressBar x:Name="SplashProgress" Height="31" Minimum="0" Maximum="100" 
             Value="{Binding ProgressValue}" Width="390" Margin="0,10,0,0">
            </ProgressBar>

            <TextBlock x:Name="SplashVersion" FontSize="10" Margin="0,10,0,0" 
           Text="{Binding Version}" HorizontalAlignment="Center"/>

        </StackPanel>

    </Grid>

</UserControl>
